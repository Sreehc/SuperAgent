APP_PORT=8080

POSTGRES_URL=jdbc:postgresql://localhost:5432/superagent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_URL=redis://localhost:6379

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=<from-container-env>
MINIO_SECRET_KEY=<from-container-env>
MINIO_BUCKET=superagent-documents

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
DOCUMENT_TASK_TOPIC=superagent.document.task
KAFKA_ENABLED=false

OPENAI_COMPATIBLE_BASE_URL=https://api.example.com/v1
OPENAI_COMPATIBLE_API_KEY=<your-api-key>
CHAT_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

RERANK_ENABLED=false
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL=

JWT_SECRET=replace-with-local-dev-secret
ACCESS_TOKEN_TTL_SECONDS=7200
REFRESH_TOKEN_TTL_SECONDS=1209600

UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_ALLOWED_EXTENSIONS=pdf,doc,docx,ppt,pptx,md,html,txt
