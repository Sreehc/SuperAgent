APP_PORT=8080

POSTGRES_URL=jdbc:postgresql://localhost:5432/superagent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_URL=redis://localhost:6379

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=<from-container-env>
MINIO_SECRET_KEY=<from-container-env>
MINIO_BUCKET=superagent-documents
MINIO_AUTO_CREATE_BUCKET=true

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
DOCUMENT_TASK_TOPIC=superagent.document.task
KAFKA_ENABLED=false
INLINE_DOCUMENT_PROCESSING_WHEN_KAFKA_DISABLED=false

OPENAI_COMPATIBLE_BASE_URL=https://api.example.com/v1
OPENAI_API_KEY=<your-api-key>
CHAT_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=openai-compatible
# 可选值：openai-compatible, local-deterministic
EMBEDDING_DIMENSION=1536

RERANK_ENABLED=false
RAG_REWRITE_ENABLED=true
RAG_SUB_QUESTION_ENABLED=true
RAG_VECTOR_TOP_K=20
RAG_KEYWORD_TOP_K=20
RAG_RRF_K=60
RAG_EVIDENCE_LIMIT=8
RAG_PER_QUESTION_EVIDENCE_CHAR_LIMIT=4000
RAG_TOTAL_EVIDENCE_CHAR_LIMIT=12000
RAG_MIN_RELEVANCE_SCORE=0.35
RAG_MAX_SUB_QUESTIONS=4

JWT_SECRET=replace-with-local-dev-secret-1234567890
ACCESS_TOKEN_TTL_SECONDS=7200
REFRESH_TOKEN_TTL_SECONDS=1209600

UPLOAD_MAX_FILE_SIZE_BYTES=52428800
